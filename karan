  NEW: "New",
  BATCHED: "Batched",
  OUT_FOR_DELIVERY: "Out for Delivery",
  COMPLETED: "Completed",
  CANCELLED: "Cancelled",
};

const ACTIONABLE_STATUSES: OrderStatus[] = [
  OrderStatus.BATCHED,
  OrderStatus.OUT_FOR_DELIVERY,
  OrderStatus.COMPLETED,
  OrderStatus.CANCELLED,
