{
  "name": "connect-campus",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "cp -r public .next/standalone/ && cp -r .next/static .next/standalone/.next/ && node .next/standalone/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"./\"",
    "format:check": "prettier --check \"./\"",
    "validate": "pnpm typecheck && pnpm lint:fix && pnpm format",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "infra:dev": "docker compose -f compose.yml -f compose.dev.yml up -d",
    "infra:dev:down": "docker compose -f compose.yml -f compose.dev.yml down",
    "infra:prod": "docker compose -f compose.yml -f compose.prod.yml up -d",
    "infra:prod:down": "docker compose -f compose.yml -f compose.prod.yml down",
    "infra:prod:up": "docker compose -f compose.yml -f compose.prod.yml up -d app-prod worker-prod && docker compose -f compose.yml -f compose.prod.yml restart nginx-prod",
    "migrator:run": "docker compose -f compose.yml -f compose.prod.yml run --rm migrator-prod",
    "migrator": "pnpm run migrator:run",
    "docker:db:logs": "docker compose logs -f db",
    "docker:db:psql": "docker exec -it campus_connect_db psql -U connect -d campus_connect",
    "redis:cli": "docker exec -it campus_connect_redis redis-cli",
    "redis:info": "docker exec campus_connect_redis redis-cli info",
    "redis:memory": "docker exec campus_connect_redis redis-cli info memory",
    "redis:clients": "docker exec campus_connect_redis redis-cli info clients",
    "redis:stats": "docker exec campus_connect_redis redis-cli info stats",
    "redis:keyspace": "docker exec campus_connect_redis redis-cli info keyspace",
    "redis:pubsub:channels": "docker exec campus_connect_redis redis-cli pubsub channels",
    "redis:pubsub:clients": "docker exec campus_connect_redis redis-cli info clients | grep pubsub_clients",
    "redis:pubsub:numsub": "docker exec campus_connect_redis redis-cli pubsub numsub",
    "redis:client:list": "docker exec campus_connect_redis redis-cli client list",
    "redis:bigkeys": "docker exec campus_connect_redis redis-cli --bigkeys",
    "redis:dbsize": "docker exec campus_connect_redis redis-cli dbsize",
    "redis:flushall": "docker exec campus_connect_redis redis-cli flushall",
    "redis:logs": "docker compose logs -f redis",
    "docker:prune": "docker system prune -af --volumes",
    "docker:images": "docker images",
    "docker:ps": "docker ps -a",
    "docker:cleanup:orphaned-files:prod": "docker compose exec worker-prod npx tsx workers/scripts/cleanup-orphaned-files.ts",
    "cleanup:orphaned-files": "tsx workers/scripts/cleanup-orphaned-files.ts",
    "cleanup:orphaned-files:dry": "tsx workers/scripts/cleanup-orphaned-files.ts --dry-run",
    "build:worker": "tsc -p tsconfig.worker.json && cp -r workers/generated dist/workers"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1068.0",
    "@aws-sdk/s3-request-presigner": "^3.1068.0",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7.8.0",
    "@prisma/client-runtime-utils": "^7.8.0",
    "@react-pdf/renderer": "^4.5.1",
    "@tanstack/query-async-storage-persister": "^5.101.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@tanstack/react-query-persist-client": "^5.101.0",
    "@tiptap/extension-placeholder": "^3.26.1",
    "@tiptap/pm": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "@use-gesture/react": "^10.3.1",
    "autoprefixer": "^10.5.0",
    "axios": "^1.18.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "better-auth": "^1.6.18",
    "bullmq": "^5.78.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.40.0",
    "input-otp": "^1.4.2",
    "ioredis": "^5.11.1",
    "isomorphic-dompurify": "^3.17.0",
    "lucide-react": "^0.577.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.11",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "postcss": "^8.5.15",
    "prom-client": "^15.1.3",
    "radix-ui": "latest",
    "react": "19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.7",
    "react-dropzone": "^15.0.0",
    "react-error-boundary": "^6.1.2",
    "react-hook-form": "^7.79.0",
    "sharp": "^0.35.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.9.3",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "concurrently": "^10.0.3",
    "depcheck": "^1.4.7",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "husky": "^9.1.7",
    "ignore-loader": "^0.1.2",
    "lint-staged": "^17.0.7",
    "lodash": "^4.18.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8"
}
